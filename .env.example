# DeepSeek API (for sentiment analysis + OASIS agent simulation)
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Claude (uses `claude` CLI with OAuth for scoring, no API key needed)
# Make sure `claude` command is available in your PATH

# MiroFish OASIS (if running separately)
MIROFISH_BASE_URL=http://localhost:5001
